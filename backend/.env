#    Credentials → OAuth 2.0 Client IDs → Android / iOS / Web Client ID
#    Paste the CLIENT ID (NOT the secret) below.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE